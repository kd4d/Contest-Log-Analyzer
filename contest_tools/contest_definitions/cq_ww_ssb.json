{
    "name": "CQ-WW-SSB",
    "dupe_check_scope": "per_band",
    "qso_common_fields_regex": "QSO:\\s+(\\d{4,5})\\s+PH\\s+(\\d{4}-\\d{2}-\\d{2})\\s+(\\d{4})\\s+([A-Z0-9/]+)\\s+(.*)",
    "qso_common_field_names": ["FrequencyRaw", "DateRaw", "TimeRaw", "MyCallRaw", "ExchangeRest"],
    "exchange_parsing_rules": {
        "CQ-WW-SSB": [
            {
                "regex": "^(\\d{2})\\s+(\\d+)\\s+([A-Z0-9/]+)\\s+(\\d{2})\\s+(\\d+)(?:\\s+(\\d))?$",
                "groups": ["SentRST", "SentNR", "Call", "RST", "Exch", "Transmitter"]
            },
            {
                "regex": "^(\\d{2})\\s+(\\d+)\\s+([A-Z0-9/]+)\\s+(\\d{2})\\s+([A-Z]{2})(?:\\s+(\\d))?$",
                "groups": ["SentRST", "SentNR", "Call", "RST", "Exch", "Transmitter"]
            }
        ]
    },
    "multiplier_rules": [
        {"name": "Zones", "value_column": "Zone_Mult", "name_column": "Zone_MultName"},
        {"name": "Countries", "value_column": "DXCC_Mult", "name_column": "DXCC_MultName"}
    ],
    "custom_multiplier_resolver": "cq_ww_multiplier_resolver",
    "operating_time_rules": {"min_off_time_minutes": 60, "single_op_max_hours": 48, "multi_op_max_hours": 48},
    "mults_from_zero_point_qsos": false,
    "multiplier_report_scope": "per_band",
    "valid_bands": ["160M", "80M", "40M", "20M", "15M", "10M"],
    "excluded_reports": []
}