{
    "name": "CQ-WPX-CW",
    "dupe_check_scope": "per_band",
    "qso_common_fields_regex": "QSO:\\s+(\\d{4,5})\\s+CW\\s+(\\d{4}-\\d{2}-\\d{2})\\s+(\\d{4})\\s+([A-Z0-9/]+)\\s+(.*)",
    "qso_common_field_names": ["FrequencyRaw", "DateRaw", "TimeRaw", "MyCallRaw", "ExchangeRest"],
    "exchange_parsing_rules": {
        "CQ-WPX-CW": {
            "regex": "^(\\d{2,3})\\s+(\\d+)\\s+([A-Z0-9/]+)\\s+(\\d{2,3})\\s+(\\d+)(?:\\s+(\\d))?$",
            "groups": ["SentRST", "SentNR", "Call", "RST", "NR", "Transmitter"]
        }
    },
    "multiplier_rules": [{"name": "Prefixes", "value_column": "Prefix_Mult", "name_column": "Prefix_MultName"}],
    "custom_multiplier_resolver": "cq_wpx_prefix",
    "operating_time_rules": {"min_off_time_minutes": 60, "single_op_max_hours": 36, "multi_op_max_hours": 48},
    "valid_bands": ["160M", "80M", "40M", "20M", "15M", "10M"],
    "excluded_reports": ["missed_multipliers", "multiplier_summary", "multipliers_by_hour"]
}