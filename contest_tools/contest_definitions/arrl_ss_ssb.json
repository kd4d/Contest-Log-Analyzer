{
    "name": "ARRL-SS-SSB",
    "dupe_check_scope": "per_band",
    "qso_common_fields_regex": "QSO:\\s+(\\d{4,5})\\s+PH\\s+(\\d{4}-\\d{2}-\\d{2})\\s+(\\d{4})\\s+([A-Z0-9/]+)\\s+(.*)",
    "qso_common_field_names": ["FrequencyRaw", "DateRaw", "TimeRaw", "MyCallRaw", "ExchangeRest"],
    "exchange_parsing_rules": {
        "ARRL-SS-SSB": {
            "regex": "^(\\d{1,4})\\s+([ABQMSU])\\s+(\\d+)\\s+([A-Z]+)\\s+([A-Z0-9/]+)\\s+(\\d{1,4})\\s+([ABQMSU])\\s+(\\d+)\\s+([A-Z]+)(?:\\s+(\\d))?$",
            "groups": ["SentNR", "SentPR", "SentCK", "SentSEC", "Call", "NR", "Precedence", "Check", "SEC", "Transmitter"]
        }
    },
    "multiplier_rules": [{"name": "Sections", "value_column": "STPROV_Mult", "name_column": "STPROV_MultName", "source_column": "SEC"}],
    "custom_multiplier_resolver": "arrl_ss_multiplier_resolver",
    "operating_time_rules": {"min_off_time_minutes": 30, "single_op_max_hours": 24, "multi_op_max_hours": 30},
    "mults_from_zero_point_qsos": false,
    "multiplier_report_scope": "per_contest",
    "valid_bands": ["160M", "80M", "40M", "20M", "15M", "10M"],
    "excluded_reports": []
}