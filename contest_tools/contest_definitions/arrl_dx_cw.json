{
    "name": "ARRL-DX-CW",
    "dupe_check_scope": "per_band",
    "qso_common_fields_regex": "QSO:\\s+(\\d{4,5})\\s+CW\\s+(\\d{4}-\\d{2}-\\d{2})\\s+(\\d{4})\\s+([A-Z0-9/]+)\\s+(.*)",
    "qso_common_field_names": ["FrequencyRaw", "DateRaw", "TimeRaw", "MyCallRaw", "ExchangeRest"],
    "exchange_parsing_rules": {
        "ARRL-DX-CW": [
            {
                "regex": "^(\\d{2,3})\\s+([A-Z]{2,4})\\s+([A-Z0-9/]+)\\s+(\\d{2,3})\\s+(\\w+)(?:\\s+(\\d))?$",
                "groups": ["SentRST", "Exch", "Call", "RST", "Power", "Transmitter"]
            },
            {
                "regex": "^(\\d{2,3})\\s+(\\w+)\\s+([A-Z0-9/]+)\\s+(\\d{2,3})\\s+([A-Z]{2,4})(?:\\s+(\\d))?$",
                "groups": ["SentRST", "Power", "Call", "RST", "Exch", "Transmitter"]
            }
        ]
    },
    "multiplier_rules": [
        {"name": "DXCC", "value_column": "DXCC_Mult", "name_column": "DXCC_MultName", "source_column": "DXCC", "applies_to": "W/VE"},
        {"name": "States/Provinces", "value_column": "STPROV_Mult", "name_column": "STPROV_MultName", "source_column": "Exch", "applies_to": "DX"}
    ],
    "custom_multiplier_resolver": "arrl_dx_multiplier_resolver",
    "operating_time_rules": {"min_off_time_minutes": 30, "single_op_max_hours": 48, "multi_op_max_hours": 48},
    "mults_from_zero_point_qsos": false,
    "multiplier_report_scope": "per_band",
    "valid_bands": ["160M", "80M", "40M", "20M", "15M", "10M"],
    "excluded_reports": []
}